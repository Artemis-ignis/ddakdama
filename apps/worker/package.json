{
  "name": "@ddakdama/worker",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:widget": "tsx scripts/generate-widget.ts",
    "dev": "pnpm generate:widget && wrangler dev",
    "deploy": "pnpm generate:widget && wrangler deploy",
    "build": "pnpm generate:widget && wrangler deploy --dry-run --outdir .wrangler-dist",
    "cf-typegen": "wrangler types",
    "lint": "eslint src scripts tests --max-warnings=0",
    "typecheck": "pnpm generate:widget && tsc --noEmit",
    "test": "pnpm generate:widget && vitest run tests"
  },
  "dependencies": {
    "@ddakdama/core": "workspace:*",
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "agents": "0.17.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260714.1",
    "@types/node": "24.10.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
